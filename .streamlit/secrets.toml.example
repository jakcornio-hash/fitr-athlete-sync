# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Community Cloud, paste these into the app's Secrets panel
# (Settings → Secrets) — do NOT commit secrets.toml to git.

# ── Google Sheets ─────────────────────────────────────────────────────────────
SHEET_ID = "your-google-sheet-id"

# Paste the full contents of your service_account.json here as a TOML table.
# On Community Cloud, Streamlit will deserialise this back to a dict for you.
[GOOGLE_SERVICE_ACCOUNT]
type = "service_account"
project_id = "your-project-id"
private_key_id = "your-key-id"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "your-sa@your-project.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-project.iam.gserviceaccount.com"

# ── Fitr API ──────────────────────────────────────────────────────────────────
FITR_ACCESS_TOKEN = ""
FITR_EMAIL = "coach@example.com"
FITR_PASSWORD = "your-fitr-password"
FITR_CLIENT_ID = "your-fitr-client-id"
FITR_CLIENT_SECRET = "your-fitr-client-secret"

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-..."
ANTHROPIC_MODEL = "claude-haiku-4-5-20251001"

# ── Competition Typeform responses sheet ──────────────────────────────────────
COMP_FORM_SHEET_ID = "your-typeform-responses-sheet-id"
COMP_FORM_TAB = "Sheet1"

# ── Recovery Typeform responses sheet ────────────────────────────────────────
RECOVERY_SHEET_ID = "your-recovery-typeform-sheet-id"

# ── Notifications (optional) ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL = ""
# Bot token for per-coach Slack notifications (xoxb-...).
# Create a Slack app at api.slack.com/apps → add chat:write scope → install to workspace.
# Invite the bot to each coach's channel before adding it to the Coaches sheet tab.
SLACK_BOT_TOKEN = ""
SMTP_FROM = ""
SMTP_PASSWORD = ""
SMTP_TO = ""

# ── Behaviour ─────────────────────────────────────────────────────────────────
LOOKBACK_DAYS = "7"
DRY_RUN = "0"
