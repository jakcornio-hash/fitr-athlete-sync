# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# === Google Sheet ===
SHEET_ID=1Fx4r3IrYeytoysX_hkarZ5I5SoQdq3ZSPZkS0Y2yDOc
# Path to the Google service-account JSON key file (see HANDOFF.md step 1).
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# === Fitr auth ===
# Two ways to authenticate. The script tries them in this order:
#
# 1) PASTE-A-TOKEN (quickest, good for first test run).
#    In Chrome on app.fitr.training, open DevTools console and run:
#       localStorage.getItem('access_token')
#    Paste the value here. Tokens expire, so this is for testing, not production.
FITR_ACCESS_TOKEN=

# 2) FULL LOGIN (for the scheduled/automated runs).
#    Your Fitr coach login + the app's OAuth client credentials.
#    See HANDOFF.md step 2 for how to capture client_id / client_secret.
FITR_EMAIL=
FITR_PASSWORD=
FITR_CLIENT_ID=
FITR_CLIENT_SECRET=

# === Claude (for summarising inbox messages & athlete notes) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === Behaviour ===
# How many days back to treat results / messages as "new".
LOOKBACK_DAYS=7
# Cap on how many conversations get a full AI summary per run (cost control).
MAX_CHAT_SUMMARIES=40
# Set to 1 for a dry run: pulls + prints, but writes NOTHING to the sheet.
DRY_RUN=0
